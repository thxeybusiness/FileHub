# Copy to .env and fill in. On Vercel, DATABASE_URL and BLOB_READ_WRITE_TOKEN
# are injected automatically when you attach a Postgres and a Blob store.

DATABASE_URL="postgresql://user:password@host:5432/db?schema=public"
AUTH_SECRET="a-long-random-secret"

# Optional: when set, files are stored in Vercel Blob instead of the local disk.
BLOB_READ_WRITE_TOKEN=""
STORAGE_DIR="./.storage"

DEFAULT_STORAGE_LIMIT="16106127360"

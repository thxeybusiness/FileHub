# Copy to .env and fill in. The only required resource is a PostgreSQL database.
# File bytes are stored in the database itself — no object storage to set up.

DATABASE_URL="postgresql://user:password@host:5432/db?schema=public"

# Optional: if unset, the session secret is derived from DATABASE_URL.
# AUTH_SECRET="a-long-random-secret"

DEFAULT_STORAGE_LIMIT="16106127360"

// FileHub — a modern Drive.
// Runs on PostgreSQL (same setup as RoadMapXey). DATABASE_URL is injected by
// the hosting env. Every table is @@map-prefixed with `filehub_` so FileHub can
// safely share a database with another app WITHOUT any table collision — Prisma
// only ever touches filehub_* tables.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  username     String?  @unique // identifiant public pour les invitations
  name         String?
  passwordHash String
  storageUsed  BigInt   @default(0)
  storageLimit BigInt   @default(1073741824) // 1 GB (Basic)
  createdAt    DateTime @default(now())

  // Abonnement (Stripe)
  plan                 String    @default("free") // "free" | "premium" | "business"
  planStatus           String? // statut de l'abonnement Stripe (active, past_due, canceled…)
  planRenewsAt         DateTime? // fin de la période en cours
  stripeCustomerId     String?   @unique
  stripeSubscriptionId String?

  nodes            Node[]
  shares           Share[]
  ownedSpaces      Space[]        @relation("SpaceOwner")
  spaceMemberships SpaceMember[]
  notifications    Notification[]

  @@index([email])
  @@map("filehub_user")
}

// Centre de notifications : invitations, arrivées dans les espaces, etc.
model Notification {
  id        String   @id @default(cuid())
  userId    String // destinataire
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String // space_created | space_joined | member_joined | space_invited
  title     String
  body      String?
  spaceId   String?
  actorName String? // qui a déclenché l'événement
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId, read])
  @@index([userId, createdAt])
  @@map("filehub_notification")
}

// Journal d'activité : trace horodatée des actions (créations, dépôts,
// partages, changements de membres…). Les identifiants d'acteur/cible sont
// stockés en clair (pas de relation FK) : le journal survit à la suppression
// du nœud ou de l'espace concerné.
model Activity {
  id         String   @id @default(cuid())
  userId     String // acteur (celui qui a agi)
  actorName  String // nom affiché au moment de l'action (instantané)
  spaceId    String? // renseigné si l'action concerne un espace commun
  nodeId     String? // nœud concerné, si applicable
  action     String // created | renamed | trashed | restored | deleted | uploaded | shared | unshared | moved | member_added | member_removed | role_changed
  targetName String // nom de l'élément concerné (instantané)
  createdAt  DateTime @default(now())

  @@index([userId, createdAt])
  @@index([spaceId, createdAt])
  @@map("filehub_activity")
}

// Un espace commun : un "drive" partagé entre plusieurs membres.
model Space {
  id        String   @id @default(cuid())
  name      String
  ownerId   String
  owner     User     @relation("SpaceOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  members SpaceMember[]
  nodes   Node[]

  @@index([ownerId])
  @@map("filehub_space")
}

model SpaceMember {
  id        String   @id @default(cuid())
  spaceId   String
  space     Space    @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      String   @default("editor") // owner | editor | viewer
  createdAt DateTime @default(now())

  @@unique([spaceId, userId])
  @@index([userId])
  @@map("filehub_space_member")
}

// A Node is either a folder or a file. Storing both in one table keeps the
// tree operations (move, list children, breadcrumb) simple.
model Node {
  id       String  @id @default(cuid())
  userId   String
  user     User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  parentId String?
  parent   Node?   @relation("Tree", fields: [parentId], references: [id], onDelete: Cascade)
  children Node[]  @relation("Tree")

  name  String
  type  String // "folder" | "file" | "doc"
  color String? // optional folder color accent

  // File-only metadata (null for folders)
  mimeType   String?
  size       BigInt  @default(0)
  storageKey String? // id of the FileBlob holding the bytes

  // Document-only : contenu HTML du traitement de texte (type "doc")
  content String?

  starred   Boolean   @default(false)
  trashed   Boolean   @default(false)
  trashedAt DateTime?

  // Espace commun : si renseigné, le nœud vit dans un espace partagé (accessible
  // à tous ses membres) au lieu du drive personnel du créateur.
  spaceId String?
  space   Space?  @relation(fields: [spaceId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  shares   Share[]
  versions FileVersion[]

  @@index([userId, parentId])
  @@index([userId, trashed])
  @@index([userId, starred])
  @@index([spaceId, parentId])
  @@map("filehub_node")
}

// Raw file bytes, stored in Postgres (same philosophy as RoadMapXey keeping its
// data in the database). No external object store required.
model FileBlob {
  id        String   @id @default(cuid())
  data      Bytes
  createdAt DateTime @default(now())

  @@map("filehub_blob")
}

// Previous byte snapshots of a file, so users can restore an older version.
model FileVersion {
  id         String   @id @default(cuid())
  nodeId     String
  node       Node     @relation(fields: [nodeId], references: [id], onDelete: Cascade)
  storageKey String
  size       BigInt   @default(0)
  mimeType   String?
  createdAt  DateTime @default(now())

  @@index([nodeId])
  @@map("filehub_file_version")
}

// A public share link for a node (file or folder).
model Share {
  id        String    @id @default(cuid())
  token     String    @unique
  nodeId    String
  node      Node      @relation(fields: [nodeId], references: [id], onDelete: Cascade)
  ownerId   String
  owner     User      @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  access        String    @default("view") // "view" | "edit"
  expiresAt     DateTime?
  passwordHash  String? // protection par mot de passe (optionnelle)
  allowDownload Boolean   @default(true) // false = aperçu seul, pas de téléchargement
  views         Int       @default(0) // nombre d'ouvertures du lien
  lastViewedAt  DateTime? // dernière ouverture
  createdAt     DateTime  @default(now())

  @@index([nodeId])
  @@map("filehub_share")
}

// Présence en temps réel : qui est actuellement dans un document (espaces
// communs). Rafraîchie par heartbeat ; les entrées obsolètes sont purgées.
model Presence {
  id        String   @id @default(cuid())
  nodeId    String
  userId    String
  name      String
  color     String
  editing   Boolean  @default(false)
  updatedAt DateTime @updatedAt

  @@unique([nodeId, userId])
  @@index([nodeId])
  @@map("filehub_presence")
}

// ────────────────────────────────────────────────────────────────────────────
// Tables auparavant provisionnées « à la volée » (CREATE TABLE IF NOT EXISTS)
// hors de ce schéma. PIÈGE CRITIQUE : le build exécute
// `prisma db push --accept-data-loss`, qui SUPPRIME toute table absente de ce
// fichier — chaque déploiement effaçait donc ces tables et leurs données
// (liens coaché→espace, membres de coaching, commentaires, versions…), d'où
// les espaces de coaching en double qui réapparaissaient sans cesse.
// Elles sont désormais déclarées ici : gérées par le schéma, jamais détruites.
// Volontairement SANS relations (colonnes texte simples) : parité exacte avec
// les tables existantes, aucune contrainte ajoutée sur des données en place.

// Lien coaché → espace FileHub caché qui sert de drive au coaché.
model CoachingSpaceLink {
  coachingId String   @id @map("coaching_id")
  spaceId    String   @unique @map("space_id")
  ownerId    String   @map("owner_id")
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  // Index unique historique sur coaching_id (doublon de la PK) : déclaré pour
  // une parité DDL exacte avec la base existante (évite un DROP INDEX au push).
  @@unique([coachingId], map: "filehub_coaching_space_coaching_uidx")
  @@index([spaceId], map: "filehub_coaching_space_space_idx")
  @@map("filehub_coaching_space")
}

// Membre invité d'un suivi de coaché (editor | viewer).
model CoachingMember {
  id        String   @id
  nodeId    String   @map("node_id")
  userId    String   @map("user_id")
  role      String   @default("editor")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@unique([nodeId, userId], map: "filehub_coaching_member_node_id_user_id_key")
  @@index([userId], map: "filehub_coaching_member_user_idx")
  @@index([nodeId], map: "filehub_coaching_member_node_idx")
  @@map("filehub_coaching_member")
}

// Commentaires sur les documents.
model DocComment {
  id         String   @id
  nodeId     String   @map("node_id")
  authorId   String   @map("author_id")
  authorName String?  @map("author_name")
  body       String
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([nodeId, createdAt], map: "filehub_comment_node_idx")
  @@map("filehub_comment")
}

// Historique de versions du CONTENU des documents (à distinguer de
// FileVersion, qui versionne les octets des fichiers importés).
model DocVersion {
  id         String   @id
  nodeId     String   @map("node_id")
  authorName String?  @map("author_name")
  content    String?
  size       Int      @default(0)
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([nodeId, createdAt(sort: Desc)], map: "filehub_doc_version_node_idx")
  @@map("filehub_doc_version")
}

// Quota quotidien d'utilisation de l'IA (un compteur par utilisateur et jour).
model AiUsage {
  userId String   @map("user_id")
  day    DateTime @db.Date
  count  Int      @default(0)

  @@id([userId, day])
  @@map("filehub_ai_usage")
}

// Limiteur de débit à fenêtre glissante (login, API sensibles…).
model RateLimit {
  bucket  String   @id
  count   Int      @default(0)
  resetAt DateTime @map("reset_at") @db.Timestamptz(6)

  @@map("filehub_rate_limit")
}
